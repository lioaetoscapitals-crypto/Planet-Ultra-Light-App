{
  "font": {
    "family": {
      "sans": {
        "$type": "fontFamily",
        "$value": "\"Noto Sans\", ui-sans-serif, system-ui, sans-serif"
      },
      "display": {
        "$type": "fontFamily",
        "$value": "\"Noto Sans\", ui-sans-serif, system-ui, sans-serif"
      }
    },
    "weight": {
      "regular": {
        "$type": "fontWeight",
        "$value": 400
      },
      "medium": {
        "$type": "fontWeight",
        "$value": 500
      },
      "semibold": {
        "$type": "fontWeight",
        "$value": 600
      },
      "bold": {
        "$type": "fontWeight",
        "$value": 700
      }
    },
    "size": {
      "xs": {
        "$type": "dimension",
        "$value": "12px"
      },
      "sm": {
        "$type": "dimension",
        "$value": "14px"
      },
      "base": {
        "$type": "dimension",
        "$value": "16px"
      },
      "lg": {
        "$type": "dimension",
        "$value": "18px"
      },
      "xl": {
        "$type": "dimension",
        "$value": "20px"
      },
      "2xl": {
        "$type": "dimension",
        "$value": "24px"
      }
    },
    "lineHeight": {
      "tight": {
        "$type": "number",
        "$value": 1.2
      },
      "snug": {
        "$type": "number",
        "$value": 1.35
      },
      "normal": {
        "$type": "number",
        "$value": 1.5
      },
      "relaxed": {
        "$type": "number",
        "$value": 1.6
      }
    }
  }
}
